/target
/credential

# ドキュメント用アーティファクト（生成物は追跡しない、ディレクトリ維持用のみ）
docs/*
!docs/images
!docs/backlog
!docs/readme
!docs/perf

# テスト実行時に作成される一時ファイル
# E2Eテスト・ベンチマークテスト用の一時ファイル
tests/fixtures/*.pem
tests/fixtures/*.toml
tests/fixtures/pids.txt
tests/fixtures/backend1/*
!tests/fixtures/backend1/.gitkeep
tests/fixtures/backend2/*
!tests/fixtures/backend2/.gitkeep
tests/fixtures/backend_h2c/*
!tests/fixtures/backend_h2c/.gitkeep

# WASM ビルドアーティファクト
# サンプルフィルタのビルド成果物
examples/wasm-filters/*/target/
examples/wasm-filters/*/Cargo.lock
tests/wasm/*.wasm

# WASM AOT サイドカーキャッシュ（F-36、起動時に <module>.wasm から自動生成される成果物）
*.cwasm

# Claude Code worktrees/local state
.claude/
tests/fixtures/proxy.pid
tests/load/results/

# Linux パッケージビルド成果物
packaging/build/
packaging/output/
packaging/staging/
packaging/staging-deb/
packaging/staging-rpm/
packaging/rpm/BUILD/
packaging/rpm/BUILDROOT/
packaging/rpm/RPMS/
packaging/rpm/SPECS/
packaging/rpm/SRPM/
packaging/rpm/SOURCES/rootfs/
# container_security ハーネス Rust ツールのビルド成果物
tools/container_security/harness/tools/target/
tools/container_security/harness/tools/Cargo.lock
# container_security 実行レポート（run.sh 毎回生成）
tools/container_security/results/
